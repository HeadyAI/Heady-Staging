# ═══════════════════════════════════════════════════════════════════════
#  HEADY SYSTEMS — Environment Configuration
#  ∞ Sacred Geometry · Organic Systems · Breathing Interfaces
# ═══════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
#
# ─── Core Service ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Sentry — CSL-Classified Error Tracking ───────────────────────────
SENTRY_DSN=
SENTRY_ORG=headyconnection-inc
SENTRY_PROJECT=heady-systems

# ─── Neon Postgres — 384D Vector Memory ───────────────────────────────
DATABASE_URL=
PGVECTOR_DIMENSIONS=384

# ─── Upstash Redis — L1/L2 Cache ─────────────────────────────────────
REDIS_URL=
REDIS_TOKEN=

# ─── Cloudflare — Edge Layer ──────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ─── Google Cloud — Origin Layer ──────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Firebase — Auth & Realtime ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Stripe — Monetization ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── LLM Providers — 6-Provider Chain ─────────────────────────────────
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ─── Langfuse — LLM Observability ────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# ─── Colab Pro+ Runtimes — Latent Space Compute ──────────────────────
COLAB_RUNTIME_1_URL=
COLAB_RUNTIME_2_URL=
COLAB_RUNTIME_3_URL=

# ─── HeadyBuddy — Companion Interface ─────────────────────────────────
BUDDY_ENCRYPTION_KEY=
BUDDY_SESSION_SECRET=

# ─── Domain Sites (9 Heady Domains) ──────────────────────────────────
HEADYME_URL=https://headyme.com
HEADYSYSTEMS_URL=https://headysystems.com
HEADYCONNECTION_URL=https://headyconnection.org
HEADYBUDDY_URL=https://headybuddy.org
HEADYMCP_URL=https://headymcp.com
HEADYIO_URL=https://headyio.com
HEADYBOT_URL=https://headybot.com
HEADYAPI_URL=https://headyapi.com
HEADYAI_URL=https://headyai.com
